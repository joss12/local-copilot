#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules/secretlint/bin/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules/secretlint/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules/secretlint/bin/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules/secretlint/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/secretlint@10.2.2/node_modules:/home/egs/Desktop/Projects/local-copilot/extension/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/secretlint.js" "$@"
else
  exec node  "$basedir/../../bin/secretlint.js" "$@"
fi
